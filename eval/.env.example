# API credentials template for the CM-LRS evaluation pipeline.
# Copy this file to `.env` (in the same directory) and fill in your own values.
# .env is gitignored by design so credentials never enter version control.

# Anthropic gateway used to call Claude Opus 4.7 and Claude Sonnet 4.6
# (and Sonnet 4.6 as the LLM-as-judge for scoring).
# In this repo's eval, requests are routed via the Radical gateway, which
# exposes Claude models on an OpenAI-compatible Responses API endpoint.
# Substitute your own endpoint and key if you route directly to Anthropic.
RAICODE_KEY=
RAICODE_BASE_URL=https://gateway.raicode.no/v1

# Groq Developer-tier API key for Llama 3.3 70B Instruct.
# Sign up at console.groq.com. Free tier hits TPM ceilings on the W2 retrieval
# workload (~24K tokens/prompt). Developer tier resolves that.
GROQ_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1

# GPT-5.5 access uses the OpenAI Codex CLI (codex exec ...) which authenticates
# against a ChatGPT account. No API key is read here. Install Codex CLI and
# run `codex login` once; the runner will subprocess into it.

# Google AI Studio API key for the fourth-judge cross-validation (Gemini 2.5 Pro).
# Used only by eval/scorer_gemini.py - generation runs do not call this provider.
# Free tier rate limits are sufficient for re-judging the 104-cell scoring battery.
# Sign up at aistudio.google.com.
GEMINI_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
